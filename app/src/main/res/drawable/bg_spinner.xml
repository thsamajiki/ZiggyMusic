<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_enabled="true">
        <layer-list>
            <item>
                <shape>
                    <solid android:color="#33000000" />
                    <stroke android:width="0.5dp" android:color="#66FFFFFF" />
                    <corners android:radius="8dp" />
                    <padding android:bottom="0dp" android:end="36dp" android:start="14dp" android:top="0dp" />
                </shape>
            </item>
            <item android:drawable="@drawable/ic_arrow_drop_down" android:end="14dp" android:gravity="center_vertical|end" />
        </layer-list>
    </item>

    <item android:state_enabled="false">
        <layer-list>
            <item>
                <shape>
                    <solid android:color="#22000000" />
                    <stroke android:width="0.5dp" android:color="#33FFFFFF" />
                    <corners android:radius="8dp" />
                    <padding android:bottom="0dp" android:end="36dp" android:start="14dp" android:top="0dp" />
                </shape>
            </item>
            <item android:drawable="@drawable/ic_arrow_drop_down" android:end="14dp" android:gravity="center_vertical|end" />
        </layer-list>
    </item>
</selector>
